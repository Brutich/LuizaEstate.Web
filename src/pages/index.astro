---
import ServiceCard from "../components/ServiceCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Луиза Алиниседова — риэлтор в Москве | Luiza Estate";
const description =
  "Luiza Estate - Луиза Алиниседова - доверенный консультант по недвижимости. Предоставляю риэлторские услуги на рынке недвижимости по Москве (Россия) и области. Услуги по покупке и продаже недвижимости на первичном, вторичном рынке, по аренде квартир. Проверяю перед покупкой недвижимость и документы.";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://luiza.estate/#website",
        url: "https://luiza.estate/",
        name: "Luiza Estate",
        inLanguage: "ru-RU",
        publisher: { "@id": "https://luiza.estate/#real-estate-agent" },
      },
      {
        "@type": "Person",
        "@id": "https://luiza.estate/#luiza-alinisedova",
        name: "Луиза Алиниседова",
        jobTitle: "Риелтор и юрист-брокер",
        description: "Риелтор и юрист-брокер с опытом работы в недвижимости более 25 лет.",
        url: "https://luiza.estate/",
        image: "https://luiza.estate/img/luiza-02.jpg",
        telephone: ["+7 495 771-55-14", "+7 926 224-92-31"],
        email: "atlas-com@yandex.ru",
        sameAs: [
          "https://t.me/Luiza_real_estate",
          "https://t.me/Luiza_estate_official",
          "https://www.instagram.com/luiza_estate/",
          "https://vk.com/lsedova2019",
        ],
        worksFor: { "@id": "https://luiza.estate/#real-estate-agent" },
      },
      {
        "@type": "RealEstateAgent",
        "@id": "https://luiza.estate/#real-estate-agent",
        name: "Luiza Estate",
        alternateName: "Луиза Алиниседова — риелтор и юрист-брокер",
        description:
          "Персональная практика Луизы Алиниседовой: операции с недвижимостью, юридическая проверка и сопровождение сделок, ипотечные и страховые услуги.",
        url: "https://luiza.estate/",
        image: "https://luiza.estate/img/luiza-02.jpg",
        telephone: ["+7 495 771-55-14", "+7 926 224-92-31"],
        email: "atlas-com@yandex.ru",
        employee: { "@id": "https://luiza.estate/#luiza-alinisedova" },
        areaServed: [
          { "@type": "City", name: "Москва" },
          { "@type": "AdministrativeArea", name: "Московская область" },
          { "@type": "City", name: "Санкт-Петербург" },
          { "@type": "City", name: "Калининград" },
          "Россия — дистанционные консультации",
        ],
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Услуги",
          itemListElement: [
            "Покупка недвижимости",
            "Продажа недвижимости",
            "Аренда и сдача недвижимости",
            "Юридическая проверка объекта и документов",
            "Сопровождение сделки",
            "Оценка рыночной стоимости недвижимости",
            "Помощь с ипотекой и рефинансированием",
            "Сделки с материнским капиталом и жилищными субсидиями",
            "Коммерческая недвижимость",
            "Оформление полисов ипотечного страхования",
            "Оформление полисов КАСКО и ОСАГО",
          ].map((name) => ({
            "@type": "Offer",
            itemOffered: { "@type": "Service", name },
          })),
        },
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://luiza.estate/"
  structuredData={structuredData}
>
  <section class="hero section">
    <div class="container hero__inner">
      <h1 class="hero__title">
        <span>Луиза</span>
        <span>Алиниседова</span>
      </h1>
      <p class="hero__subtitle">Доверенный консультант по недвижимости</p>
      <div class="hero__actions">
        <a class="button button--secondary" href="tel:+74957715514">
          <svg class="button__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.62 10.79a15.46 15.46 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z" fill="currentColor" />
          </svg>
          Позвонить
        </a>
        <a class="button button--primary" href="https://t.me/Luiza_real_estate">
          <svg class="button__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21.54 2.38a1.45 1.45 0 0 0-1.48-.2L2.84 8.82c-1.18.46-1.17 1.12-.21 1.41l4.42 1.38 1.7 5.25c.2.56.1.78.68.78.45 0 .65-.2.9-.45l2.14-2.08 4.45 3.29c.82.45 1.41.22 1.61-.76l2.91-13.72c.3-1.2-.45-1.74-1.9-1.54ZM8.1 11.3l9.96-6.28c.5-.3.96-.14.58.2l-8.22 7.42-.32 3.42-2-4.76Z" fill="currentColor" />
          </svg>
          Написать
        </a>
      </div>
    </div>
  </section>

  <section class="about section">
    <div class="container">
      <div class="about__card">
        <div class="about__photo">
          <img src="/img/luiza-02.jpg" alt="Луиза Алиниседова" width="1080" height="1350" loading="eager" />
        </div>
        <div class="about__content">
          <h2>Обо мне</h2>
          <div class="about__text">
            <p>
              Юрист-брокер с 25-летним опытом в сфере недвижимости Москвы и Московской области.
              Моя практика охватывает широкий спектр операций, от простых сделок купли-продажи до
              сложных межрегиональных обменов. Обладаю глубокими знаниями рынка, что позволяет
              предлагать клиентам оптимальные решения, соответствующие их потребностям и бюджету.
            </p>
            <p>
              Как практикующий специалист, я сопровождаю сделки на всех этапах, обеспечивая
              юридическую чистоту и безопасность. Мои брокерские услуги включают подбор недвижимости,
              оценку рыночной стоимости, организацию показов и переговоров.
            </p>
            <p>
              Также оказываю экспертную помощь в оформлении ипотеки, использовании материнского
              капитала и жилищных субсидий. Сотрудничаю с ведущими банками и страховыми компаниями, что
              позволяет предлагать клиентам выгодные условия кредитования и страхования.
            </p>
            <p>
              Моя цель – сделать процесс покупки или продажи недвижимости максимально комфортным и
              эффективным для каждого клиента.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="services section">
    <div class="container services__inner">
      <h2 class="section-title">Услуги</h2>
      <p class="section-lead">Опыт, которому вы можете доверять</p>
      <div class="services__grid">
        <ServiceCard title="Консультации" symbol="consulting">
          Предоставляю консультации по вопросам налогов, прав собственности и рефинансирования
          долга. А также провожу оценку стоимости недвижимости и анализ рынка.
        </ServiceCard>
        <ServiceCard title="Сделки с недвижимостью" symbol="property">
          Помогаю в сдаче и аренде жилых и нежилых помещений. Консультирую по вопросам покупки и
          аренды коммерческой недвижимости.
        </ServiceCard>
        <ServiceCard title="Cопровождение" symbol="support">
          Осуществляю проверку юридической чистоты объектов перед покупкой. Сопровождаю вас до
          момента подписания акта приема-передачи.
        </ServiceCard>
      </div>
    </div>
  </section>

  <section class="contacts section">
    <div class="container contacts__inner">
      <h2 class="section-title">Контакты</h2>
      <a class="contacts__email" href="mailto:atlas-com@yandex.ru">atlas-com@yandex.ru</a>
      <a class="contacts__phone" href="tel:+74957715514">+7 495 771 55 14</a>
    </div>
  </section>

  <footer class="site-footer section">
    <div class="container site-footer__inner">
      <nav class="social-links" aria-label="Социальные сети">
        <a class="social-link" href="https://t.me/+7-Qh5us1_043ZTgy" aria-label="Telegram">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21.54 2.38a1.45 1.45 0 0 0-1.48-.2L2.84 8.82c-1.18.46-1.17 1.12-.21 1.41l4.42 1.38 1.7 5.25c.2.56.1.78.68.78.45 0 .65-.2.9-.45l2.14-2.08 4.45 3.29c.82.45 1.41.22 1.61-.76l2.91-13.72c.3-1.2-.45-1.74-1.9-1.54ZM8.1 11.3l9.96-6.28c.5-.3.96-.14.58.2l-8.22 7.42-.32 3.42-2-4.76Z" fill="currentColor" />
          </svg>
        </a>
        <a class="social-link" href="https://www.instagram.com/luiza_estate/" aria-label="Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="2" />
            <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
            <circle cx="17.4" cy="6.6" r="1.2" fill="currentColor" />
          </svg>
        </a>
        <a class="social-link" href="https://vk.com/lsedova2019" aria-label="VK">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.9566 15.9194C22.434 15.2864 21.8402 14.7191 21.266 14.1704C21.0618 13.9753 20.8506 13.7736 20.6471 13.573C20.0628 12.9965 20.0415 12.7799 20.5041 12.125C20.8242 11.6736 21.1636 11.2216 21.4917 10.7845C21.7894 10.3879 22.0973 9.97775 22.3923 9.56629L22.4529 9.48169C23.0168 8.6943 23.5999 7.88011 23.9103 6.89791C23.9909 6.63878 24.0755 6.25745 23.882 5.93859C23.6887 5.61999 23.3136 5.52279 23.0482 5.4774C22.9169 5.45493 22.7866 5.45186 22.6656 5.45186L18.9728 5.4492L18.9423 5.44893C18.3839 5.44893 18.0076 5.71446 17.792 6.26079C17.5862 6.78278 17.36 7.33864 17.102 7.86717C16.5885 8.91963 15.9363 10.1318 14.9927 11.1428L14.9528 11.1858C14.8413 11.3067 14.7151 11.4435 14.6228 11.4435C14.6087 11.4435 14.5933 11.4408 14.5758 11.4353C14.3803 11.3584 14.2492 10.8809 14.2551 10.6587L14.2527 6.34225C14.2527 6.32732 14.2516 6.31252 14.2497 6.29772C14.1557 5.59753 13.9477 5.16166 13.1614 5.00627C13.1405 5.00207 13.1192 5 13.0979 5H9.25805C8.63245 5 8.28775 5.2566 7.96372 5.64066C7.87625 5.74333 7.69419 5.95706 7.78443 6.21632C7.87599 6.47945 8.1732 6.53572 8.26998 6.55398C8.75037 6.64625 9.02115 6.94278 9.09785 7.46091C9.23176 8.36063 9.24821 9.32096 9.14964 10.4831C9.12216 10.8061 9.06779 11.0556 8.97822 11.2687C8.95741 11.3185 8.88362 11.4808 8.80837 11.4809C8.78446 11.4809 8.71529 11.4714 8.58931 11.3838C8.29145 11.1779 8.07351 10.884 7.81944 10.521C6.9551 9.28829 6.22968 7.93031 5.60144 6.36852C5.36845 5.79359 4.9333 5.47173 4.37562 5.46226C3.76283 5.45286 3.20726 5.44833 2.67739 5.44833C2.09843 5.44833 1.56168 5.45373 1.03756 5.46473C0.58887 5.47273 0.278515 5.60846 0.115213 5.86846C-0.0483542 6.12866 -0.0377184 6.47045 0.146856 6.88418C1.62438 10.199 2.96403 12.6092 4.49069 14.6993C5.56042 16.1618 6.63338 17.1742 7.867 17.8849C9.16669 18.6352 10.6232 19 12.3196 19C12.5119 19 12.7108 18.9953 12.9113 18.9858C13.897 18.9373 14.2628 18.5773 14.309 17.6087C14.331 17.1137 14.3846 16.5946 14.6258 16.1518C14.778 15.8729 14.9199 15.8729 14.9665 15.8729C15.0564 15.8729 15.1677 15.9146 15.2874 15.9928C15.5019 16.1342 15.6859 16.3235 15.8367 16.4889C15.9787 16.646 16.1191 16.8048 16.2596 16.9636C16.5628 17.3063 16.8763 17.6606 17.2039 17.9967C17.9208 18.7327 18.7105 19.0565 19.6176 18.9862H23.0034C23.0106 18.9862 23.0178 18.9859 23.025 18.9855C23.3624 18.963 23.6546 18.7741 23.8267 18.4673C24.0398 18.0873 24.0356 17.6024 23.8152 17.17C23.5651 16.6811 23.2408 16.2634 22.9566 15.9194Z" fill="currentColor" />
          </svg>
        </a>
      </nav>
      <p>© 2025 Луиза Алиниседова - Консультант по недвижимости - Россия, Москва</p>
      <p>Сайт создан <a href="https://bimo.tools/">BIMO Tools</a></p>
    </div>
  </footer>
</BaseLayout>
